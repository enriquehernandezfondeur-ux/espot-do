# ── Espot · variables de entorno (ejemplo) ──────────────────────
# Copiar a .env.local y rellenar. NUNCA commitear secretos reales.

# Supabase (Auth + DB + Storage)
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # sensible: bypassa RLS

# Sitio
NEXT_PUBLIC_SITE_URL=https://espot.do
SITE_PASSWORD=                                    # gate de "vista previa privada" (vacío = sitio público)
PREVIEW_HMAC_SECRET=                              # opcional, para el token de preview

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=Espot <no-reply@espot.do>
EMAIL_REPLY_TO=soporte@espot.do

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_FROM=whatsapp:+1XXXXXXXXXX

# Pagos (Azul PaymentPage)
AZUL_MERCHANT_ID=your_merchant_id
AZUL_MERCHANT_NAME=your_merchant_name
AZUL_MERCHANT_TYPE=your_merchant_type
AZUL_CURRENCY_CODE=DOP
AZUL_PRIVATE_KEY=your_azul_private_key            # (antes documentado mal como AZUL_AUTH_KEY)
AZUL_PAYMENT_PAGE_URL=https://pagos.azul.com.do/PaymentPage/Default.aspx
AZUL_RETURN_BASE_URL=https://espot.do
AZUL_ITBIS_RATE=0.18
# Modo de prueba de pago — DEBE estar vacío/ausente en producción:
PAYMENT_TEST_MODE=
NEXT_PUBLIC_PAYMENT_TEST_MODE=

# Google (Maps + Calendar OAuth)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_maps_key
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://espot.do/api/auth/google-calendar/callback

# Admin / cron / health
SUPERADMIN_EMAIL=tu-correo-admin@example.com
CRON_SECRET=your_cron_secret
HEALTH_SECRET=your_health_secret                  # (antes documentado mal como HEALTH_CHECK_SECRET)

# IA (análisis de solicitudes de host)
ANTHROPIC_API_KEY=your_anthropic_key

# Social
NEXT_PUBLIC_BEHOLD_FEED_ID=your_behold_feed_id

# Número de WhatsApp de soporte (formato 1809XXXXXXX, sin +). Si vacío, se oculta el botón.
NEXT_PUBLIC_SUPPORT_WHATSAPP=
